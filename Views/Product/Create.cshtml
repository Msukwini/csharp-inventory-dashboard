@model inventory_dashboard.Models.Product
@{
    ViewData["Title"] = "Create Product";
}

<div style="max-width: 600px; margin: 0 auto;">
    <a href="/Product" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back</a>
    <h2>Add Product</h2>

    <div class="card" style="margin-top: 1.5rem;">
        <form asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group">
                    <label asp-for="Name">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Product name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="SKU">SKU</label>
                    <input asp-for="SKU" class="form-control" placeholder="BEV-001" />
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2" placeholder="Brief description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div class="form-group">
                    <label asp-for="Price">Price (R)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" value="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="StockQuantity">Stock</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" value="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Category">Category</label>
                    <input asp-for="Category" class="form-control" placeholder="Beverages" />
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
            </div>

            <div class="flex gap-2 mt-4">
                <button type="submit" class="btn-primary">Add Product</button>
                <a href="/Product" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
