@model inventory_dashboard.Models.Product
@{
    ViewData["Title"] = "Restock Product";
}

<div style="max-width: 400px; margin: 0 auto;">
    <a href="/Product/LowStock" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back</a>
    <h2>Restock @Model.Name</h2>

    <div class="card" style="margin-top: 1.5rem;">
        <form asp-action="Restock">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Name" />
            <div class="form-group">
                <label>Current Stock</label>
                <p style="color: var(--muted-fg);">@Model.StockQuantity</p>
            </div>
            <div class="form-group">
                <label asp-for="StockQuantity">New Stock Quantity</label>
                <input asp-for="StockQuantity" class="form-control" type="number" />
            </div>
            <div class="form-group">
                <label asp-for="Price">New Price (R)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
            </div>
            <div class="flex gap-2">
                <button type="submit" class="btn-primary">Update Stock</button>
                <a href="/Product/LowStock" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
