@model inventory_dashboard.Models.Product
@{ ViewData["Title"] = "Delete Product"; }
<div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-red-600 mb-6">🗑️ Delete Product</h2>
    <div class="card bg-red-50 border border-red-200">
        <p class="text-lg text-gray-800 mb-4">Are you sure you want to delete this product?</p>
        <dl class="grid grid-cols-2 gap-4">
            <dt class="font-semibold">Name</dt>
            <dd>@Model.Name</dd>
            <dt class="font-semibold">SKU</dt>
            <dd>@Model.SKU</dd>
            <dt class="font-semibold">Price</dt>
            <dd>R @Model.Price</dd>
            <dt class="font-semibold">Stock</dt>
            <dd>@Model.StockQuantity</dd>
        </dl>
        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="flex gap-2">
                <button type="submit" class="btn-danger">Delete</button>
                <a href="/Product" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
