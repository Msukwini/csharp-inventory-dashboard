@model inventory_dashboard.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div style="max-width: 500px; margin: 0 auto;">
    <a href="/Product" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back to Products</a>
    <h2 style="color: var(--destructive);">🗑️ Delete Product</h2>

    <div class="card" style="margin-top: 1rem; border-color: var(--destructive);">
        <p style="color: var(--foreground); font-weight: 500;">Are you sure you want to delete this product?</p>
        <p style="color: var(--muted-foreground); font-size: 0.9rem;">
            <strong style="color: var(--foreground);">Name:</strong> @Model.Name<br />
            <strong style="color: var(--foreground);">SKU:</strong> @Model.SKU<br />
            <strong style="color: var(--foreground);">Price:</strong> R @Model.Price<br />
            <strong style="color: var(--foreground);">Stock:</strong> @Model.StockQuantity<br />
            <strong style="color: var(--foreground);">Category:</strong> @Model.Category
        </p>
        <p style="color: var(--muted-foreground); font-size: 0.85rem;">
            This action will <strong>soft‑delete</strong> the product. It will be hidden but not permanently removed.
        </p>

        <form asp-action="Delete" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="flex gap-2">
                <button type="submit" class="btn-danger">Yes, Delete</button>
                <a href="/Product" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
