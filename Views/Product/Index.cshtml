@model IEnumerable<inventory_dashboard.Models.Product>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="flex justify-between items-center mb-6">
    <h2>📦 Products</h2>
    <a href="/Product/ExportCsv" class="btn-secondary">📤 Export</a>
    <a href="/Product/Create" class="btn-primary">+ Add Product</a>
</div>

<!-- Search / Filter -->
<div class="card mb-6">
    <form method="get" class="grid grid-cols-4 gap-4">
        <div class="form-group">
            <label>Search (Name/SKU)</label>
            <input type="text" name="searchTerm" class="form-control" placeholder="e.g. Coffee" value="@ViewBag.CurrentSearchTerm" />
        </div>
        <div class="form-group">
            <label>Category</label>
            <select name="category" class="form-control">
                <option value="">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat" selected="@(ViewBag.CurrentCategory == cat ? "selected" : null)">@cat</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Min Stock</label>
            <input type="number" name="minStock" class="form-control" placeholder="e.g. 5" value="@ViewBag.CurrentMinStock" />
        </div>
        <div class="form-group">
            <label>Max Stock</label>
            <input type="number" name="maxStock" class="form-control" placeholder="e.g. 20" value="@ViewBag.CurrentMaxStock" />
        </div>
        <div class="flex items-end gap-2">
            <button type="submit" class="btn-primary">Filter</button>
            <a href="/Product" class="btn-secondary">Clear</a>
        </div>
    </form>
</div>

<!-- Product Grid -->
<div class="grid grid-cols-3 gap-6">
    @foreach (var product in Model)
    {
        <div class="card product-card">
            <div class="flex justify-between items-start">
                <span class="product-name">@product.Name</span>
                @if (product.StockQuantity <= 10)
                {
                    <span class="badge badge-low">Low</span>
                }
            </div>
            <span class="product-meta">@product.Category · @product.SKU</span>
            <p style="font-size: 0.9rem; color: var(--muted-fg);">@product.Description</p>
            <div class="flex justify-between items-center">
                <span class="product-price">R @product.Price.ToString("N2")</span>
                <span class="product-stock">@product.StockQuantity in stock</span>
            </div>
            <div class="product-actions">
                <a href="/Product/Edit/@product.Id">Edit</a>
                <a href="/Product/Details/@product.Id">View</a>
                <a href="/Product/Delete/@product.Id" style="color: #EF4444;">Delete</a>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="card text-center" style="padding: 3rem;">
        <p style="color: var(--muted-fg);">No products found. <a href="/Product/Create">Add one now</a>.</p>
    </div>
}
