@model IEnumerable<inventory_dashboard.Models.Product>
@{
    ViewData["Title"] = "Low Stock";
}

<h2 style="margin-bottom: 0.25rem;">Low Stock</h2>
<p style="color: var(--muted-fg); margin-bottom: 1.5rem;">@Model.Count() products with 10 or fewer units remaining</p>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Price</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td><strong>@product.Name</strong></td>
                    <td>@product.Category</td>
                    <td>@product.StockQuantity left</td>
                    <td>R @product.Price.ToString("N2")</td>
                    <td><a href="/Product/Restock/@product.Id" class="btn-primary" style="padding: 0.3rem 0.8rem; font-size: 0.8rem;">Restock</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
