@model inventory_dashboard.Models.Note
@{
    ViewData["Title"] = "Delete Note";
}

<div style="max-width: 500px; margin: 0 auto;">
    <a href="/Notes" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back to Notes</a>
    <h2 style="color: var(--destructive);">🗑️ Delete Note</h2>

    <div class="card" style="margin-top: 1rem; border-color: var(--destructive);">
        <p>Are you sure you want to delete this note?</p>
        <p style="color: var(--muted-foreground); font-size: 0.9rem;">
            <strong>Title:</strong> @Model.Title<br />
            <strong>Category:</strong> @Model.Category<br />
            <strong>Content:</strong> @Model.Content
        </p>
        <p style="color: var(--muted-foreground); font-size: 0.85rem;">
            This action will <strong>soft‑delete</strong> the note. It will be hidden but not permanently removed.
        </p>

        <form asp-action="Delete" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="flex gap-2">
                <button type="submit" class="btn-danger">Yes, Delete</button>
                <a href="/Notes" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
