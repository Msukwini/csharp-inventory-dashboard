<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Dashboard</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />

    <!-- Tailwind (for layout utilities only – colors come from our CSS) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Main Stylesheet (Figma‑accurate + Light/Dark + Modal) -->
    <link rel="stylesheet" href="/css/site.css" />

    <!-- Confetti Library -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1"></script>
</head>

<body>
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var isLoginPage = controller == "Login";
    }

    <!-- =========================== -->
    <!-- NAVBAR (hidden on Login)    -->
    <!-- =========================== -->
    @if (!isLoginPage)
    {
        <nav class="navbar-custom">
            <div class="navbar-brand">
                <span class="brand-icon">📦</span>
                <span class="brand-gold">Inventory</span>
                <span class="brand-light">Dashboard</span>
            </div>

            <div class="navbar-links">
                <a href="/Notes">Notes</a>
                <a href="/">Home</a>
                <a href="/Product">Products</a>
                <a href="/Product/LowStock">Low Stock</a>
                <a href="/Order">Orders</a>
                <a href="/AuditLog">Audit Log</a>

                <button id="darkModeToggle" class="theme-toggle" title="Toggle theme">🌙</button>

                @{
                    var username = Context.Session.GetString("Username");
                }
                @if (!string.IsNullOrEmpty(username))
                {
                    <span class="navbar-username">@username</span>
                    <a href="/Login/Logout" class="navbar-logout">Logout</a>
                }
                else
                {
                    <a href="/Login" class="navbar-login">Login</a>
                }
            </div>
        </nav>
    }

    <!-- =========================== -->
    <!-- MAIN CONTENT               -->
    <!-- =========================== -->
    <main class="main-container">
        @RenderBody()
    </main>

    <!-- =========================== -->
    <!-- OUT‑OF‑STOCK MODAL          -->
    <!-- =========================== -->
    <div id="outOfStockModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <span class="modal-icon">🚨</span>
                <h2 class="modal-title">Out of Stock!</h2>
                <button class="modal-close-btn" onclick="closeOutOfStockModal()">✕</button>
            </div>
            <div class="modal-body">
                <p class="modal-message">
                    <strong id="oosProductName">Product</strong> is completely out of stock!
                </p>
                <p class="modal-sub-message">Please restock immediately to avoid lost sales.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-primary btn-danger-ack" onclick="closeOutOfStockModal()">Acknowledge</button>
                <a href="/Product/LowStock" class="btn-secondary">View Low Stock</a>
            </div>
        </div>
    </div>

    <!-- =========================== -->
    <!-- TOAST NOTIFICATIONS         -->
    <!-- =========================== -->
    <div id="alertToast" class="alert-toast alert-toast-warning" style="display: none;">
        <strong>⚠️ Low Stock Alert!</strong>
        <p id="alertMessage">Product is running low!</p>
    </div>

    <div id="messageToast" class="alert-toast" style="display: none;">
        <strong id="messageTitle"></strong>
        <p id="messageContent"></p>
    </div>

    <!-- =========================== -->
    <!-- LOADING OVERLAY             -->
    <!-- =========================== -->
    <div id="loadingOverlay">
        <div class="spinner-box">
            <div class="spinner"></div>
            <p class="loading-text">Loading...</p>
        </div>
    </div>

    <!-- =========================== -->
    <!-- SCRIPTS                     -->
    <!-- =========================== -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js">
    </script>

    <script>
        // =========================================================
        // 1. SIGNALR – LOW STOCK & OUT OF STOCK
        // =========================================================
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/stockHub")
            .build();

        connection.on("ReceiveAlert", (productName, stock) => {
            // --- OUT OF STOCK (stock === 0) ---
            if (stock <= 0) {
                document.getElementById('oosProductName').textContent = productName;
                document.getElementById('outOfStockModal').style.display = 'flex';

                // Urgent beep
                try {
                    const ctx = new(window.AudioContext || window.webkitAudioContext)();
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.frequency.value = 600;
                    osc.type = 'square';
                    gain.gain.value = 0.3;
                    osc.start();
                    setTimeout(() => osc.stop(), 400);
                } catch (_) { /* silent fallback */ }
                return;
            }

            // --- LOW STOCK (1–10) ---
            const toast = document.getElementById("alertToast");
            const msg = document.getElementById("alertMessage");
            msg.textContent = `${productName} is low on stock! Only ${stock} left.`;
            toast.style.display = "block";

            try {
                const ctx = new(window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.frequency.value = 800;
                gain.gain.value = 0.2;
                osc.start();
                setTimeout(() => osc.stop(), 200);
            } catch (_) {}

            clearTimeout(toast._timeout);
            toast._timeout = setTimeout(() => { toast.style.display = "none"; }, 5000);
        });

        connection.start().catch(err => console.error("SignalR error:", err));

        // =========================================================
        // 2. MODAL HELPERS
        // =========================================================
        window.closeOutOfStockModal = function() {
            document.getElementById('outOfStockModal').style.display = 'none';
        };

        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('outOfStockModal');
            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target === this) closeOutOfStockModal();
                });
            }
        });

        // =========================================================
        // 3. DARK / LIGHT TOGGLE
        // =========================================================
        const toggle = document.getElementById('darkModeToggle');
        if (toggle) {
            toggle.addEventListener('click', function() {
                document.body.classList.toggle('light-mode');
                this.textContent = document.body.classList.contains('light-mode') ? '🌙' : '☀️';
                localStorage.setItem('lightMode', document.body.classList.contains('light-mode'));
            });

            if (localStorage.getItem('lightMode') === 'true') {
                document.body.classList.add('light-mode');
                toggle.textContent = '🌙';
            }
        }

        // =========================================================
        // 4. TOAST HELPER
        // =========================================================
        function showMessage(title, message, type = 'success') {
            const toast = document.getElementById('messageToast');
            const titleEl = document.getElementById('messageTitle');
            const contentEl = document.getElementById('messageContent');

            toast.className = 'alert-toast alert-toast-' + type;
            toast.style.display = 'block';
            titleEl.textContent = title;
            contentEl.textContent = message;

            clearTimeout(toast._timeout);
            toast._timeout = setTimeout(() => { toast.style.display = 'none'; }, 4000);
        }

        // =========================================================
        // 5. LOADING SPINNER
        // =========================================================
        document.querySelectorAll('form:not([data-no-spinner])').forEach(form => {
            form.addEventListener('submit', function(e) {
                if (this.checkValidity && !this.checkValidity()) return;
                document.getElementById('loadingOverlay').style.display = 'flex';
            });
        });

        // =========================================================
        // 6. CONFETTI (global)
        // =========================================================
        window.fireConfetti = function() {
            confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>