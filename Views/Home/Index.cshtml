@model DashboardData
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-6">
    <h1>Welcome back, <span style="color: var(--primary);">@Context.Session.GetString("Username")</span> 👋</h1>
    <p style="color: var(--muted-fg);">Today is <span id="liveClock" style="font-weight: 500;"></span></p>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-4 gap-6 mb-6">
    <div class="card stat-card">
        <span class="stat-icon">📦</span>
        <span class="stat-label">Total Products</span>
        <span class="stat-value">@Model.TotalProducts</span>
    </div>
    <div class="card stat-card">
        <span class="stat-icon">⚠️</span>
        <span class="stat-label">Low Stock</span>
        <span class="stat-value" style="color: var(--primary);">@Model.LowStockCount</span>
    </div>
    <div class="card stat-card">
        <span class="stat-icon">📋</span>
        <span class="stat-label">Pending Orders</span>
        <span class="stat-value" style="color: #2A9D8F;">@Model.PendingOrders</span>
    </div>
    <div class="card stat-card">
        <span class="stat-icon">💰</span>
        <span class="stat-label">Stock Value</span>
        <span class="stat-value">R @Model.StockValue.ToString("N2")</span>
    </div>
</div>

<div class="grid grid-cols-2 gap-6 mb-6">
    <div class="card stat-card">
        <span class="stat-icon">💵</span>
        <span class="stat-label">Order Revenue</span>
        <span class="stat-value" style="color: var(--primary);">R @Model.OrderRevenue.ToString("N2")</span>
    </div>
    <div class="card stat-card">
        <span class="stat-icon">📊</span>
        <span class="stat-label">Total Items</span>
        <span class="stat-value">@Model.TotalProducts</span>
    </div>
</div>

<!-- Chart -->
<div class="card chart-container">
    <h3 style="font-family: var(--font-display); margin-bottom: 1rem;">Weekly Orders – Last 7 Days</h3>
    <canvas id="ordersChart" height="120"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Live Clock
    function updateClock() {
        const now = new Date();
        document.getElementById('liveClock').textContent = now.toLocaleString('en-US', {
            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Chart
    const ctx = document.getElementById('ordersChart').getContext('2d');
    const weeklyData = @Html.Raw(Json.Serialize(Model.WeeklyOrders));
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: Object.keys(weeklyData),
            datasets: [{
                label: 'Orders',
                data: Object.values(weeklyData),
                backgroundColor: 'rgba(212, 163, 115, 0.7)',
                borderColor: '#D4A373',
                borderWidth: 2,
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--muted-fg') } }
            },
            scales: {
                y: { beginAtZero: true, stepSize: 1, grid: { color: 'rgba(255,255,255,0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });
</script>
