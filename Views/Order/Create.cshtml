@model inventory_dashboard.Models.Order
@{
    ViewData["Title"] = "Create Order";
    var products = ViewBag.Products as IEnumerable<inventory_dashboard.Models.Product> ?? new List<inventory_dashboard.Models.Product>();
}

<div style="max-width: 700px; margin: 0 auto;">
    <a href="/Order" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back</a>
    <h2 style="margin-bottom: 1.5rem;">Create Order</h2>

    <form asp-action="Create" id="orderForm" method="post">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 1rem; padding: 0.75rem; border: 1px solid #EF4444; border-radius: 8px; background: rgba(239,68,68,0.08);"></div>

        <div class="card" style="margin-bottom: 1.5rem;">
            <h3 style="font-family: var(--font-body); font-weight: 600; font-size: 1rem; margin-bottom: 0.75rem;">Order Details</h3>
            <div class="form-group">
                <label asp-for="CustomerId">Customer ID / Name</label>
                <input asp-for="CustomerId" class="form-control" placeholder="Enter your Customer ID or Name" />
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Notes">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Special instructions..."></textarea>
            </div>
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
            <h3 style="font-family: var(--font-body); font-weight: 600; font-size: 1rem; margin-bottom: 0.75rem;">Products</h3>
            <div id="orderItems">
                <div class="item-row grid grid-cols-3 gap-4 items-end mb-2">
                    <div class="form-group">
                        <label>Product</label>
                        <select name="items[0].ProductId" class="form-control product-select">
                            <option value="0">-- Select --</option>   <!-- ✅ Changed value to 0 -->
                            @foreach (var p in products)
                            {
                                <option value="@p.Id" data-price="@p.Price">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <input type="number" name="items[0].Quantity" class="form-control qty" min="1" value="1" />
                    </div>
                    <div class="form-group">
                        <label>Price (snapshot)</label>
                        <input type="number" name="items[0].Price" class="form-control price" step="0.01" value="0" readonly />
                    </div>
                </div>
            </div>
            <button type="button" id="addRow" class="btn-secondary" style="padding: 0.3rem 0.8rem;">+ Add row</button>
            <div style="margin-top: 1rem; font-size: 1.2rem; font-weight: 600;">
                Grand Total: <span id="grandTotal">R 0.00</span>
            </div>
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
            <h3 style="font-family: var(--font-body); font-weight: 600; font-size: 1rem; margin-bottom: 0.75rem;">Purchase Request</h3>
            <p style="font-size: 0.85rem; color: var(--muted-fg); margin-bottom: 0.5rem;">For items not in stock — note to order from supplier.</p>
            <div class="grid grid-cols-3 gap-4">
                <div class="form-group">
                    <label>Product Name</label>
                    <input type="text" id="otherProductName" name="otherProductName" class="form-control" placeholder="e.g. Stapler" />
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input type="text" id="otherProductQty" name="otherProductQuantity" class="form-control" placeholder="10" />   <!-- ✅ string input -->
                </div>
                <div class="form-group">
                    <label>Estimated Price</label>
                    <input type="text" id="otherProductPrice" name="otherProductPrice" class="form-control" placeholder="25.00" />   <!-- ✅ string input -->
                </div>
            </div>
        </div>

        <div class="flex gap-2">
            <button type="submit" class="btn-primary">Create Order</button>
            <a href="/Order" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let rowIndex = 1;

        // Add row
        document.getElementById('addRow').addEventListener('click', function() {
            const container = document.getElementById('orderItems');
            const newRow = container.firstElementChild.cloneNode(true);
            // Update names
            newRow.querySelectorAll('select, input').forEach(el => {
                const name = el.getAttribute('name');
                if (name) {
                    el.setAttribute('name', name.replace(/\[\d+\]/, `[${rowIndex}]`));
                }
                if (el.classList.contains('product-select')) el.value = '0';   // ✅ default to 0
                if (el.classList.contains('qty')) el.value = 1;
                if (el.classList.contains('price')) el.value = 0;
            });
            container.appendChild(newRow);
            rowIndex++;
            attachRowEvents(newRow);
            updateGrandTotal();
        });

        function attachRowEvents(row) {
            const select = row.querySelector('.product-select');
            const qty = row.querySelector('.qty');
            const price = row.querySelector('.price');
            select.addEventListener('change', function() {
                const selected = this.options[this.selectedIndex];
                if (selected && selected.dataset.price) {
                    price.value = parseFloat(selected.dataset.price).toFixed(2);
                } else {
                    price.value = '';
                }
                updateGrandTotal();
            });
            qty.addEventListener('input', updateGrandTotal);
            price.addEventListener('input', updateGrandTotal);
        }

        function updateGrandTotal() {
            const rows = document.querySelectorAll('.item-row');
            let total = 0;
            rows.forEach(row => {
                const qty = parseFloat(row.querySelector('.qty').value) || 0;
                const price = parseFloat(row.querySelector('.price').value) || 0;
                total += qty * price;
            });
            document.getElementById('grandTotal').textContent = 'R ' + total.toFixed(2);
        }

        // Attach events to initial row
        attachRowEvents(document.querySelector('.item-row'));
        updateGrandTotal();
    </script>
}