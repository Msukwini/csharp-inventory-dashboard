@model inventory_dashboard.Models.Order
@{
    ViewData["Title"] = "Order Details";
}

<div style="max-width: 800px; margin: 0 auto;">
    <a href="/Order" class="btn-secondary" style="margin-bottom: 1rem; display: inline-block;">← Back</a>
    <h2>Order #ORD-@Model.Id.ToString("D3")</h2>

    <div class="card" style="margin-bottom: 1.5rem;">
        <dl class="grid grid-cols-2 gap-4" style="margin: 0;">
            <dt style="color: var(--muted-fg);">Customer ID</dt>
            <dd>CUST-@Model.CustomerId.ToString("D3")</dd>
            <dt style="color: var(--muted-fg);">Date</dt>
            <dd>@Model.OrderDate.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt style="color: var(--muted-fg);">Status</dt>
            <dd><span class="badge @(Model.Status == "Approved" ? "badge-approved" : Model.Status == "Pending" ? "badge-pending" : "badge-rejected")">@Model.Status</span></dd>
            <dt style="color: var(--muted-fg);">Total</dt>
            <dd style="font-weight: 600;">R @Model.TotalAmount.ToString("N2")</dd>
            <dt style="color: var(--muted-fg);">Notes</dt>
            <dd>@(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)</dd>
        </dl>
    </div>

    <h3 style="margin-bottom: 0.75rem;">Order Items</h3>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.Quantity</td>
                        <td>R @item.Price.ToString("N2")</td>
                        <td>R @(item.Price * item.Quantity).ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" style="text-align: right;">Grand Total</th>
                    <th>R @Model.TotalAmount.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="flex gap-2" style="margin-top: 1.5rem;">
        @if (Model.Status == "Pending")
        {
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post" style="display:inline;" id="approveForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-primary">Approve</button>
            </form>
            <form asp-action="Reject" asp-route-id="@Model.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">Reject</button>
            </form>
        }
        @if (Model.Status != "Approved" && (DateTime.UtcNow - Model.CreatedAt).TotalHours <= 1)
        {
            <a href="/Order/Edit/@Model.Id" class="btn-secondary">Edit</a>
        }
        <a href="/Order/DownloadInvoice/@Model.Id" class="btn-primary" style="background: #3B82F6;">Download Invoice</a>
        <a href="/Order" class="btn-secondary">Back to List</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Confetti on approve
        const approveForm = document.getElementById('approveForm');
        if (approveForm) {
            approveForm.addEventListener('submit', function(e) {
                e.preventDefault();
                if (typeof fireConfetti === 'function') fireConfetti();
                else confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
                setTimeout(() => { this.submit(); }, 500);
            });
        }
    </script>
}
