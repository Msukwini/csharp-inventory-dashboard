@model IEnumerable<inventory_dashboard.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="flex justify-between items-center mb-6">
    <h2>📋 Orders</h2>
    <div class="flex gap-2">
        <a href="/Order/ExportCsv" class="btn-secondary">📤 Export</a>
        <a href="/Order/Create" class="btn-primary">+ New Order</a>
    </div>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Customer ID</th>
                <th>Date</th>
                <th>Total</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>ORD-@order.Id.ToString("D3")</td>
                    <td>@order.CustomerId</td>   <!-- CustomerId is string -->
                    <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                    <td>R @order.TotalAmount.ToString("N2")</td>
                    <td>
                        <span class="badge @(order.Status == "Approved" ? "badge-approved" : order.Status == "Pending" ? "badge-pending" : "badge-rejected")">
                            @order.Status
                        </span>
                    </td>
                    <td class="order-actions">
                        <a href="/Order/Details/@order.Id" class="view">View</a>
                        @if (order.Status != "Approved")
                        {
                            <a href="/Order/Delete/@order.Id" class="delete">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="card text-center" style="padding: 3rem;">
        <p style="color: var(--muted-fg);">No orders yet. <a href="/Order/Create">Create your first order</a>.</p>
    </div>
}